      <div class="kpi"><div class="lbl">Avg Turn</div><div class="val mono">${cur.turnDaysAvg.toFixed(1)}<span style="font-size:11px;color:var(--ink-3)">d</span></div><div class="delta">target 11.0d</div></div>
