/* ============================================================
   AI ASSISTANT — canned but thoughtful
   ============================================================ */

const CANNED = {
  vacancy_risk: ()=>{
    const atRisk = UNITS.filter(u=>{
      const s = u.history[currentMonth];
      if (s!=="in-turn" && s!=="vacant") return false;
      // count consecutive non-occupied months
      let c = 0;
      for (let m=currentMonth; m>=0 && u.history[m]!=="occupied"; m--) c++;
      return c>=2;
    });
    const ids = atRisk.map(u=>u.idx);
    const numbers = atRisk.map(u=>u.number);
    return {
      set: new Set(ids),
      html: `
        <p>I found <span class="hl">${atRisk.length} unit${atRisk.length===1?"":"s"}</span> with stalled turn cycles beyond the <span class="hl">14-day threshold</span>. I've surfaced them in the twin.</p>
        <ul>
          ${atRisk.map(u=>{
            let c=0; for (let m=currentMonth; m>=0 && u.history[m]!=="occupied"; m--) c++;
            const wo = u.workOrders.find(w=>w.status!=="closed");
            return `<li><span class="cite">${u.number}</span> &nbsp;~${c*30}d idle${wo?` · blocker: <em>${wo.cat.toLowerCase()}</em> (${wo.ageDays}d)`:""}</li>`;
          }).join("")}
        </ul>
        <p>The highest impact is <span class="hl">${atRisk[0]?.number}</span> — at $${atRisk[0]?.rent}/mo, every week idle costs ~$${Math.round((atRisk[0]?.rent||0)/4.3).toLocaleString()}.</p>
        <div class="footnote">Grounded in AppFolio turn states · maintenance queue · last sync 3m ago.</div>
      `
    };
  },

  month_signal: ()=>{
    const cur = AGG[currentMonth];
    const prev = AGG[Math.max(0,currentMonth-1)];
    const delinqUnits = UNITS.filter(u=>u.history[currentMonth]==="delinquent");
    const woUnits = UNITS.filter(u=>u.history[currentMonth]==="work-order");
    const emph = new Set([...delinqUnits, ...woUnits].map(u=>u.idx));
    return {
      set: emph,
      html: `
        <p><span class="hl">${MONTHS[currentMonth]}</span> at a glance.</p>
        <ul>
          <li>Occupancy: <span class="hl">${cur.occupancyPct.toFixed(1)}%</span> (${(cur.occupancyPct-prev.occupancyPct>=0?"+":"")}${(cur.occupancyPct-prev.occupancyPct).toFixed(1)}pt MoM).</li>
          <li>Turn cycle trending to <span class="hl">${cur.turnDaysAvg.toFixed(1)}d</span> vs an 11.0d target — the drag is concentrated on Floor 2.</li>
          <li>Delinquency is <span class="hl">${cur.del} unit${cur.del===1?"":"s"}</span> (${cur.delinquencyPct.toFixed(1)}%). Repeat offender: ${delinqUnits[0]?.number || "n/a"}.</li>
          <li>${cur.wo} open work order${cur.wo===1?"":"s"} — 2 have aged past SLA.</li>
        </ul>
        <p>Net: property is <span class="hl">operationally stable</span> but turn velocity is the weakest link this month.</p>
        <div class="footnote">Human review recommended before any tenant-facing action.</div>
      `
    };
  },

  focus_week: ()=>{
    const cur = AGG[currentMonth];
    const actions = [];
    UNITS.forEach(u=>{
      const s = u.history[currentMonth];
      if (s==="in-turn"){
        let c=0; for (let m=currentMonth; m>=0 && u.history[m]!=="occupied"; m--) c++;
        if (c>=2) actions.push({unit:u, priority: u.rent*c, action:`Unblock turn — ~${c*30}d idle`, tag:"turn"});
      }
      if (s==="delinquent") actions.push({unit:u, priority: u.rent*2.5, action:"Initiate collection workflow", tag:"del"});
      const stalled = u.workOrders?.find(w=>w.status==="stalled");
      if (stalled) actions.push({unit:u, priority: stalled.ageDays*100, action:`Escalate ${stalled.cat.toLowerCase()} vendor`, tag:"wo"});
    });
    actions.sort((a,b)=>b.priority-a.priority);
    const top = actions.slice(0,4);
    return {
      set: new Set(top.map(a=>a.unit.idx)),
      html: `
        <p>Ranked by estimated impact on <span class="hl">NOI this month</span>:</p>
        <ul>
          ${top.map((a,i)=>`<li><span class="cite">${i+1}. ${a.unit.number}</span> &nbsp;${a.action}</li>`).join("")}
        </ul>
        <p>Addressing the top two alone would recover approximately <span class="hl">$${Math.round((top[0]?.unit.rent+top[1]?.unit.rent||0)/4).toLocaleString()}</span> in avoidable loss this cycle.</p>
        <div class="footnote">Prioritization weights are tunable — this is a suggestion, not a directive.</div>
      `
    };
  },

  patterns: ()=>{
    // floor 2 woes
    const f2wo = UNITS.filter(u=>u.floor===1 && u.workOrders.length>0);
    const emph = new Set(f2wo.map(u=>u.idx));
    return {
      set: emph,
      html: `
        <p>Two signals worth surfacing from the 12-month ledger:</p>
        <ul>
          <li><span class="hl">Floor 2 is over-represented</span> in maintenance activity — ${f2wo.length} units carry open or historical work orders (${Math.round(f2wo.length/6*100)}% of the floor) vs. a ${Math.round(28)}% property average. Likely a shared system (HVAC or plumbing riser).</li>
          <li>Work orders touched by vendor <span class="hl">Casa Maintenance</span> resolve ~3.2d slower than portfolio baseline. Worth reviewing contract terms.</li>
        </ul>
        <p>Neither is a crisis — but both are the kind of pattern a static dashboard would miss. The twin compounds these observations over time.</p>
        <div class="footnote">Pattern detection runs nightly · thresholds are configurable.</div>
      `
    };
  }
};

const thread = document.getElementById("thread");

document.querySelectorAll(".chip").forEach(c=>{
  c.addEventListener("click", ()=>{
    document.querySelectorAll(".chip").forEach(x=>x.classList.remove("active"));
    c.classList.add("active");
    const q = c.dataset.q;
    runQuery(q, c.textContent.replace(/^\d+/,"").trim());
  });
});

function runQuery(key, label){
  // user message
  const userMsg = document.createElement("div");
  userMsg.className = "msg user";
  userMsg.textContent = label;
  thread.appendChild(userMsg);

  // typing indicator
  const tMsg = document.createElement("div");
  tMsg.className = "msg claude";
  tMsg.innerHTML = `<div class="who">Twin · thinking</div><div class="typing"><span></span><span></span><span></span></div>`;
  thread.appendChild(tMsg);
  thread.scrollTop = thread.scrollHeight;

  setTimeout(()=>{
    const {set, html} = CANNED[key]();
    highlightSet = set;
    tMsg.innerHTML = `<div class="who">Twin · response</div>${html}`;
    thread.scrollTop = thread.scrollHeight;
  }, 900);
}

