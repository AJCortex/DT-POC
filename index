    occupied:"var(--moss)", vacant:"var(--ghost)", "in-turn":"var(--amber)",
    "work-order":"var(--slate)", delinquent:"var(--rose)"
  }[s];
  const statusLabel = s.replace("-"," ");
  const openWOs = u.workOrders.filter(w=>w.status!=="closed");
  const closedWOs = u.workOrders.filter(w=>w.status==="closed");

  return `
    <div class="unit-head">
      <div class="eyebrow"><span>Unit Inspector</span><span class="close">close ✕</span></div>
      <h3>Unit ${u.number}</h3>
      <div class="addr">FLOOR ${u.floor+1} · ${u.beds} BED · ${u.sqft} SF</div>
      <div class="status-pill" style="border-color:${statusColor};color:${statusColor}">
        <span class="sw" style="background:${statusColor}"></span>${statusLabel.toUpperCase()}
      </div>
    </div>

    <div class="unit-body">
      ${ s==="occupied" || s==="delinquent" || s==="work-order" ? `
        <div class="tenant-card">
          <div class="avatar">${u.tenant.split(" ").map(s=>s[0]).join("")}</div>
          <div class="info"><div class="name">${u.tenant}</div>
            <div class="sub">LEASE START ${u.leaseStart} · ${u.beds}BR</div>
          </div>
        </div>
      ` : `<div style="font-size:12px;color:var(--ink-3);font-style:italic;padding:6px 0">No current occupant.</div>`}

      <div class="row"><span class="k">Current rent</span><span class="v">$${u.rent.toLocaleString()}/mo</span></div>
      <div class="row"><span class="k">Market estimate</span><span class="v">$${(u.rent + (u.floor*25 + u.beds*40)).toLocaleString()}/mo</span></div>
      <div class="row"><span class="k">Days in state</span><span class="v">${daysInState(u)}</span></div>
      <div class="row"><span class="k">Last AppFolio sync</span><span class="v">3m ago</span></div>
    </div>

    <div class="section">
      <h4>Work orders · ${u.workOrders.length}</h4>
      ${u.workOrders.length===0 ? `<div style="font-size:12px;color:var(--ink-3)">No history on record.</div>` :
        [...openWOs, ...closedWOs].map(w=>`
          <div class="wo-item">
            <div class="wo-top"><span>${w.id} · ${w.cat}</span><span class="${w.status}">${w.status.toUpperCase()} · ${w.ageDays}d</span></div>
            <div class="desc">${w.d}</div>
          </div>
        `).join("")
      }
    </div>

    <div class="section">
      <h4>12-month timeline</h4>
      <div style="display:flex;gap:2px;margin-top:4px">
        ${u.history.map((h,i)=>{
          const c = {
            occupied:"var(--moss)",vacant:"var(--ghost)","in-turn":"var(--amber)",
            "work-order":"var(--slate)",delinquent:"var(--rose)"
          }[h];
          const border = i===currentMonth ? "1.5px solid var(--accent)" : "1px solid transparent";
          return `<div title="${MONTHS[i]} · ${h}" style="flex:1;height:18px;background:${c};border:${border};cursor:pointer" onclick="window.__setMonth(${i})"></div>`;
        }).join("")}
      </div>
      <div style="display:flex;justify-content:space-between;font-family:'Geist Mono';font-size:9.5px;color:var(--ink-4);margin-top:3px">
        <span>${MONTHS[0]}</span><span>${MONTHS[N_MONTHS-1]}</span>
      </div>
    </div>
  `;
}

function daysInState(u){
  let count = 0;
  const s = u.history[currentMonth];
  for (let m=currentMonth; m>=0 && u.history[m]===s; m--) count += 30;
  return `~${count}d`;
}

function selectUnit(idx){
  selectedIdx = idx;
  highlightSet = null;
  refreshDetail();
}
window.__selectUnit = selectUnit;
