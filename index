function attentionList(){
  // find interesting units this month
  const flagged = [];
  UNITS.forEach(u=>{
    const s = u.history[currentMonth];
    if (s==="in-turn"){
      // roughly estimate turn days as how many consecutive turn/vacant months
      let days = 0;
      for (let m=currentMonth; m>=0 && (u.history[m]==="in-turn"||u.history[m]==="vacant"); m--) days += 18;
      flagged.push({u, reason:`Turn cycle · ${days}d`, tag:"in-turn"});
    } else if (s==="delinquent"){
      flagged.push({u, reason:"Rent 30d+ past due", tag:"delinquent"});
    } else if (s==="work-order"){
      const stalled = u.workOrders.find(w=>w.status==="stalled");
      if (stalled) flagged.push({u, reason:`${stalled.cat} stalled · ${stalled.ageDays}d`, tag:"work-order"});
    }
  });
  flagged.sort((a,b)=>{ const ord={"delinquent":0,"in-turn":1,"work-order":2}; return ord[a.tag]-ord[b.tag];});
  const top = flagged.slice(0,4);
  if (top.length===0) return `<div style="color:var(--ink-3);font-size:12px">Nothing flagged. The property is running clean at ${MONTHS[currentMonth]}.</div>`;
  return top.map(f=>`
    <div class="row" onclick="window.__selectUnit(${f.u.idx})" style="cursor:pointer">
      <span class="k">Unit ${f.u.number}</span>
      <span class="v" style="color:var(--${f.tag==='delinquent'?'rose':f.tag==='in-turn'?'amber':'slate'})">${f.reason}</span>
    </div>
  `).join("");
}

